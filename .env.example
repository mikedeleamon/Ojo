# Example environment variables for Ojo
# Copy this to a file named .env in the project root and fill in the values.

# Secret used to sign JWT tokens — set a long random string in production
JWT_SECRET=

# Apple WeatherKit (server-side, REST API)
# These credentials must remain secret and be provided to the server process only.
# Generate from the Apple Developer Portal: enable WeatherKit on a Services ID
# and on an AuthKey p8. The private key is the PEM contents of the .p8 file,
# with literal `\n` newlines so dotenv keeps it on one line.
APPLE_TEAM_ID=ABC123XYZ4
APPLE_WEATHERKIT_KEY_ID=ABCDEF1234
APPLE_WEATHERKIT_SERVICE_ID=com.ojostudio.ojo.weatherkit
APPLE_WEATHERKIT_PRIVATE_KEY=APPLE_WEATHERKIT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqG...\n-----END PRIVATE KEY-----

# Optional: override server base used by the React app in development
# e.g. http://localhost:4000
REACT_APP_SERVER_BASE=

# MongoDB connection string (MongoDB Atlas URI)
MONGO_URI=

# Comma-separated origins allowed by CORS for development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Server port (default 4000)
PORT=4000

# Cloudflare R2 credentials for outfit image storage
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ACCOUNT_ID=xxxxxxxxxxxxx  # from the endpoint URL
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev #set this to your custom domain once configured in Cloudflare
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx # Resend API key for transactional emails (e.g. password reset) - https://resend.com/ (optional, but recommended to avoid email deliverability issues with Gmail SMTP)
RESEND_FROM_EMAIL=Ojo <noreply@ojoapp.io>
GOOGLE_IOS_CLIENT_ID= your_ios_client_id
GOOGLE_WEB_CLIENT_ID= your_web_client_id

# Facebook App ID — required by Instagram since Jan 2023 for "Share to Story"
# to work at all (without it Instagram shows "doesn't currently support
# sharing to Stories"). Create a Meta developer app at
# https://developers.facebook.com/apps and copy its App ID here. No app
# review is needed for this basic share flow.
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Public base URL for shared-content landing pages (the Instagram Story "Link"
# sticker points here). Leave blank in dev — shares still work, just without
# the tappable link sticker back into the app. See server/src/routes/share.ts.
EXPO_PUBLIC_SHARE_BASE_URL=https://ojoapp.io