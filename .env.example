# Example environment variables for Ojo
# Copy this to a file named .env in the project root and fill in the values.

# AccuWeather API key (server-side)
# This key should remain secret and be provided to the server process only.
ACCUWEATHER_API_KEY=
# (Optional) AccuWeather base URL, leave default unless using a proxy
ACCUWEATHER_BASE_URL=

# If you must expose a client-side key (not recommended), use the REACT_APP_ prefix below.
# Prefer keeping keys on the server and calling the server proxy from the React app.
REACT_APP_ACCUWEATHER_API_KEY=

# Optional: override server base used by the React app in development
# e.g. http://localhost:4000
REACT_APP_SERVER_BASE=

# MongoDB connection string (MongoDB Atlas URI)
MONGO_URI=

# Comma-separated origins allowed by CORS for development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Server port (default 4000)
PORT=4000
