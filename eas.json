{
  "build": {
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "language": "en-US",
        "appleId": "mikeamon@ojoapp.io",
        "ascAppId": "6743219085",
        "appleTeamId": "37L8H5D9PQ"
      },
      "android": {
        "track": "production"
      }
    }
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
