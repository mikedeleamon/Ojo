{
  "expo": {
    "name": "Ojo",
    "slug": "ojo",
    "version": "1.0.0",
    "scheme": "ojo",
    "orientation": "portrait",
    "icon": "./assets/ojo_app_icon@1x.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ojostudio.ojo",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Ojo uses your location to fetch local weather for outfit suggestions.",
        "NSCameraUsageDescription": "Ojo uses your camera so you can photograph clothing items to add to your closet.",
        "NSPhotoLibraryUsageDescription": "Ojo uses your photo library so you can add images of your clothing items.",
        "NSUserNotificationsUsageDescription": "Ojo sends daily outfit suggestions and weather alerts to help you dress for the day.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "37L8H5D9PQ"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logos/ojoLogo.png",
        "backgroundColor": "#87DE5A"
      },
      "package": "com.ojostudio.ojo",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ojo uses your location for local weather."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ojo uses your photo library to add clothing images to add to your closet.",
          "cameraPermission": "Ojo uses your camera so you can photograph clothing items to add to your closet."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Ojo uses your camera so you can photograph clothing items to add to your closet.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/ojo_app_icon@1x.png",
          "color": "#87DE5A",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logos/ojoLogo.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.555153415751-ejhgihp9r6tgkssuj8qhchess3blbmml"
        }
      ],
      "./plugins/withOjoAppGroup"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "117165ec-1076-4eba-84f5-3c2a1676e965"
      }
    }
  }
}
