{
  "name": "ojo-native",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "chmod -R u+w ios/Pods 2>/dev/null; rm -rf node_modules ios/build ios/Pods ios/.xcode.env.local android/build android/.gradle",
    "clean-install": "rm -rf node_modules ios/build ios/Pods ios/.xcode.env.local android/build android/.gradle && npx expo install && cd ios && pod install && cd ..",
    "dev": "concurrently --names \"server,expo\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix server\" \"expo start\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "axios": "^1.15.2",
    "babel-preset-expo": "^55.0.18",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.3.3"
  },
  "private": true
}
