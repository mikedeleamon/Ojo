# Database
MONGODB_URI=mongodb://localhost:27017/ojo

# JWT
JWT_SECRET=your_jwt_secret_here

# Server
PORT=4000
ALLOWED_ORIGIN=http://localhost:8081

# AccuWeather API
ACCUWEATHER_API_KEY=your_accuweather_key
ACCUWEATHER_BASE_URL=https://dataservice.accuweather.com

# Expo Notifications
EXPO_ACCESS_TOKEN=your_expo_token

# Cloudflare R2 (Object Storage)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=ojo-wardrobe-images
# Set this to your custom domain once configured in Cloudflare (step below)
# R2_PUBLIC_URL=https://images.ojo.app
