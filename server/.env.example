# Database
MONGODB_URI=mongodb://localhost:27017/ojo

# JWT
JWT_SECRET=your_jwt_secret_here

# Server
PORT=4000
ALLOWED_ORIGIN=http://localhost:8081

# AccuWeather API
ACCUWEATHER_API_KEY=your_accuweather_key
ACCUWEATHER_BASE_URL=https://dataservice.accuweather.com

# Expo Notifications
EXPO_ACCESS_TOKEN=your_expo_token

# Gmail OAuth (Trip Planner)
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: https://www.googleapis.com/auth/gmail.readonly
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/trips/gmail/callback
# Custom URL scheme for your Expo app (used to redirect back after OAuth)
APP_DEEP_LINK_SCHEME=ojo

# Cloudflare R2 (Object Storage)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=ojo-wardrobe-images
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev #set this to your custom domain once configured in Cloudflare
# Set this to your custom domain once configured in Cloudflare (step below)
